generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id               String           @id @default(cuid())
  name             String
  email            String           @unique
  phone            String?
  address          String?
  logo             String?
  subscriptionPlan SubscriptionPlan @default(FREE)
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  users               User[]
  companyModules      CompanyModule[]
  companySubmodules   CompanySubmodule[]
  employees           Employee[]
  candidates          Candidate[]
  customers           Customer[]
  suppliers           Supplier[]
  products            Product[]
  orders              Order[]
  invoices            Invoice[]
  quotes              Quote[]
  projects            Project[]
  stockMovements      StockMovement[]
  payroll             Payroll[]
  announcements       Announcement[]
  budgetLines         BudgetLine[]
  treasuryEntries     TreasuryEntry[]
  journalEntries      JournalEntry[]
  inventorySessions   InventorySession[]
  equipment           Equipment[]
  maintenanceRequests MaintenanceRequest[]
  maintenanceOrders   MaintenanceOrder[]
  maintenanceLogs     MaintenanceLog[]
  workCenters         WorkCenter[]
  boms                Bom[]
  productionOrders    ProductionOrder[]

  @@map("companies")
}

enum SubscriptionPlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

model User {
  id          String    @id @default(cuid())
  companyId   String
  firstName   String
  lastName    String
  email       String    @unique
  password    String
  role        UserRole  @default(OPERATOR)
  department  String?
  avatar      String?
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company          Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sentMessages     Message[]       @relation("SentMessages")
  receivedMessages Message[]       @relation("ReceivedMessages")
  notifications    Notification[]
  auditLogs        AuditLog[]
  assignedProjects ProjectMember[]
  leaveRequests    LeaveRequest[]
  expenseReports   ExpenseReport[]
  evaluations      Evaluation[]
  announcements    Announcement[]

  @@map("users")
}

enum UserRole {
  OPERATOR
  MANAGER
  DIRECTOR
  ADMIN
  SUPER_ADMIN
}

model Module {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  description String?
  icon        String?
  color       String?
  sortOrder   Int     @default(0)
  isCore      Boolean @default(false)

  subModules     SubModule[]
  companyModules CompanyModule[]

  @@map("modules")
}

model SubModule {
  id          String  @id @default(cuid())
  moduleId    String
  name        String
  slug        String  @unique
  description String?
  icon        String?
  sortOrder   Int     @default(0)
  route       String?

  module            Module             @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  companySubmodules CompanySubmodule[]

  @@map("sub_modules")
}

model CompanyModule {
  id        String  @id @default(cuid())
  companyId String
  moduleId  String
  enabled   Boolean @default(true)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  module  Module  @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([companyId, moduleId])
  @@map("company_modules")
}

model CompanySubmodule {
  id          String  @id @default(cuid())
  companyId   String
  submoduleId String
  enabled     Boolean @default(true)

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  submodule SubModule @relation(fields: [submoduleId], references: [id], onDelete: Cascade)

  @@unique([companyId, submoduleId])
  @@map("company_submodules")
}

model Message {
  id         String    @id @default(cuid())
  senderId   String
  receiverId String
  content    String    @default("")
  isRead     Boolean   @default(false)
  readAt     DateTime?
  createdAt  DateTime  @default(now())
  fileUrl    String?
  fileName   String?
  fileType   String?
  fileSize   Int?

  sender   User @relation("SentMessages", fields: [senderId], references: [id])
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id])

  @@map("messages")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(INFO)
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  TASK
  MESSAGE
}

model Employee {
  id           String         @id @default(cuid())
  companyId    String
  firstName    String
  lastName     String
  email        String
  phone        String?
  position     String
  department   String
  salary       Float
  hireDate     DateTime
  birthDate    DateTime?
  address      String?
  contractType ContractType   @default(CDI)
  status       EmployeeStatus @default(ACTIVE)
  managerId    String?
  cvUrl        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  leaveRequests  LeaveRequest[]
  expenseReports ExpenseReport[]
  payrolls       Payroll[]
  evaluations    Evaluation[]

  @@map("employees")
}

enum ContractType {
  CDI
  CDD
  INTERIM
  STAGE
  FREELANCE
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  SUSPENDED
  TERMINATED
}

model LeaveRequest {
  id         String      @id @default(cuid())
  employeeId String
  userId     String
  type       LeaveType
  startDate  DateTime
  endDate    DateTime
  days       Int
  reason     String?
  status     LeaveStatus @default(PENDING)
  approvedBy String?
  createdAt  DateTime    @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@map("leave_requests")
}

enum LeaveType {
  ANNUAL
  SICK
  MATERNITY
  PATERNITY
  UNPAID
  OTHER
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model ExpenseReport {
  id          String        @id @default(cuid())
  employeeId  String
  userId      String
  title       String
  amount      Float
  currency    String        @default("DZD")
  date        DateTime
  category    String
  description String?
  receipt     String?
  status      ExpenseStatus @default(PENDING)
  createdAt   DateTime      @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@map("expense_reports")
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
  REIMBURSED
}

model Payroll {
  id         String    @id @default(cuid())
  companyId  String
  employeeId String
  month      Int
  year       Int
  baseSalary Float
  bonus      Float     @default(0)
  deductions Float     @default(0)
  netSalary  Float
  paidAt     DateTime?
  createdAt  DateTime  @default(now())

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, month, year])
  @@map("payrolls")
}

model Evaluation {
  id          String   @id @default(cuid())
  employeeId  String
  evaluatorId String
  period      String
  score       Float
  comments    String?
  goals       Json?
  createdAt   DateTime @default(now())

  employee  Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  evaluator User     @relation(fields: [evaluatorId], references: [id])

  @@map("evaluations")
}

model Customer {
  id        String         @id @default(cuid())
  companyId String
  name      String
  email     String?
  phone     String?
  address   String?
  country   String?
  type      CustomerType   @default(INDIVIDUAL)
  status    CustomerStatus @default(LEAD)
  source    String?
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  orders   Order[]
  invoices Invoice[]
  quotes   Quote[]

  @@map("customers")
}

enum CustomerType {
  INDIVIDUAL
  COMPANY
}

enum CustomerStatus {
  LEAD
  PROSPECT
  ACTIVE
  INACTIVE
  LOST
}

model Supplier {
  id           String   @id @default(cuid())
  companyId    String
  name         String
  email        String?
  phone        String?
  address      String?
  country      String?
  taxId        String?
  paymentTerms Int      @default(30)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  supplierId   String
  reference    String              @unique
  status       PurchaseOrderStatus @default(DRAFT)
  totalAmount  Float
  currency     String              @default("DZD")
  orderDate    DateTime
  deliveryDate DateTime?
  notes        String?
  createdAt    DateTime            @default(now())

  supplier Supplier            @relation(fields: [supplierId], references: [id])
  items    PurchaseOrderItem[]

  @@map("purchase_orders")
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  CONFIRMED
  RECEIVED
  CANCELLED
}

model PurchaseOrderItem {
  id              String @id @default(cuid())
  purchaseOrderId String
  productId       String
  quantity        Float
  unitPrice       Float
  totalPrice      Float

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])

  @@map("purchase_order_items")
}

model Product {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  sku         String
  description String?
  category    String?
  unit        String   @default("pcs")
  buyPrice    Float
  sellPrice   Float
  stockQty    Float    @default(0)
  minStockQty Float    @default(0)
  maxStockQty Float?
  location    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company          Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  orderItems       OrderItem[]
  purchaseItems    PurchaseOrderItem[]
  stockMovements   StockMovement[]
  inventoryLines   InventoryLine[]
  quoteItems       QuoteItem[]
  boms             Bom[]
  bomItems         BomItem[]
  productionOrders ProductionOrder[]

  @@unique([companyId, sku])
  @@map("products")
}

model StockMovement {
  id        String            @id @default(cuid())
  companyId String
  productId String
  type      StockMovementType
  quantity  Float
  unitPrice Float?
  reference String?
  notes     String?
  createdAt DateTime          @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("stock_movements")
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
  TRANSFER
}

model Order {
  id           String      @id @default(cuid())
  companyId    String
  customerId   String
  reference    String      @unique
  status       OrderStatus @default(DRAFT)
  totalAmount  Float
  currency     String      @default("DZD")
  orderDate    DateTime
  deliveryDate DateTime?
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  company  Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer    @relation(fields: [customerId], references: [id])
  items    OrderItem[]
  invoices Invoice[]

  @@map("orders")
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model OrderItem {
  id         String @id @default(cuid())
  orderId    String
  productId  String
  quantity   Float
  unitPrice  Float
  discount   Float  @default(0)
  totalPrice Float

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Invoice {
  id          String        @id @default(cuid())
  companyId   String
  customerId  String
  orderId     String?
  reference   String        @unique
  status      InvoiceStatus @default(DRAFT)
  subtotal    Float
  taxRate     Float         @default(19)
  taxAmount   Float
  totalAmount Float
  currency    String        @default("DZD")
  issueDate   DateTime
  dueDate     DateTime
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime      @default(now())

  company  Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer      @relation(fields: [customerId], references: [id])
  order    Order?        @relation(fields: [orderId], references: [id])
  items    InvoiceItem[]

  @@map("invoices")
}

model InvoiceItem {
  id          String @id @default(cuid())
  invoiceId   String
  description String
  quantity    Float  @default(1)
  unitPrice   Float
  totalPrice  Float

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

// ─── QUOTES (DEVIS) ──────────────────────────────────────────────────────────

model Quote {
  id          String      @id @default(cuid())
  companyId   String
  customerId  String
  reference   String      @unique
  status      QuoteStatus @default(DRAFT)
  subtotal    Float
  taxRate     Float       @default(19)
  taxAmount   Float
  totalAmount Float
  currency    String      @default("DZD")
  issueDate   DateTime
  validUntil  DateTime
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  company  Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer    @relation(fields: [customerId], references: [id])
  items    QuoteItem[]

  @@map("quotes")
}

model QuoteItem {
  id          String  @id @default(cuid())
  quoteId     String
  productId   String?
  description String
  quantity    Float
  unitPrice   Float
  discount    Float   @default(0)
  totalPrice  Float

  quote   Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@map("quote_items")
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

model Project {
  id          String        @id @default(cuid())
  companyId   String
  name        String
  description String?
  status      ProjectStatus @default(PLANNING)
  priority    Priority      @default(MEDIUM)
  startDate   DateTime
  endDate     DateTime?
  budget      Float?
  progress    Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  company Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  members ProjectMember[]
  tasks   Task[]

  @@map("projects")
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model ProjectMember {
  id        String @id @default(cuid())
  projectId String
  userId    String
  role      String @default("member")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@map("project_members")
}

model Task {
  id          String     @id @default(cuid())
  projectId   String
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  assigneeId  String?
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("tasks")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  oldData   Json?
  newData   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

// ─── ANNOUNCEMENTS ───────────────────────────────────────────────────────────

model Announcement {
  id        String               @id @default(cuid())
  companyId String
  title     String
  content   String
  authorId  String
  priority  AnnouncementPriority @default(NORMAL)
  isActive  Boolean              @default(true)
  expiresAt DateTime?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id])

  @@map("announcements")
}

enum AnnouncementPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// ─── BUDGET ──────────────────────────────────────────────────────────────────

model BudgetLine {
  id        String     @id @default(cuid())
  companyId String
  year      Int
  month     Int?
  category  String
  label     String
  budgeted  Float
  actual    Float      @default(0)
  type      BudgetType @default(EXPENSE)
  notes     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("budget_lines")
}

enum BudgetType {
  INCOME
  EXPENSE
}

// ─── TREASURY ────────────────────────────────────────────────────────────────

model TreasuryEntry {
  id          String       @id @default(cuid())
  companyId   String
  type        TreasuryType
  amount      Float
  description String
  reference   String?
  category    String?
  date        DateTime
  createdAt   DateTime     @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("treasury_entries")
}

enum TreasuryType {
  CREDIT
  DEBIT
}

// ─── ACCOUNTING ──────────────────────────────────────────────────────────────

model JournalEntry {
  id          String   @id @default(cuid())
  companyId   String
  reference   String
  date        DateTime
  description String
  totalDebit  Float    @default(0)
  totalCredit Float    @default(0)
  isBalanced  Boolean  @default(false)
  createdAt   DateTime @default(now())

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines   JournalLine[]

  @@map("journal_entries")
}

model JournalLine {
  id             String @id @default(cuid())
  journalEntryId String
  accountCode    String
  accountLabel   String
  debit          Float  @default(0)
  credit         Float  @default(0)

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@map("journal_lines")
}

// ─── INVENTORY ───────────────────────────────────────────────────────────────

model InventorySession {
  id          String          @id @default(cuid())
  companyId   String
  reference   String
  status      InventoryStatus @default(DRAFT)
  notes       String?
  startedAt   DateTime        @default(now())
  completedAt DateTime?

  company Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines   InventoryLine[]

  @@map("inventory_sessions")
}

enum InventoryStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model InventoryLine {
  id                 String  @id @default(cuid())
  inventorySessionId String
  productId          String
  theoreticalQty     Float
  countedQty         Float?
  variance           Float?
  notes              String?

  inventorySession InventorySession @relation(fields: [inventorySessionId], references: [id], onDelete: Cascade)
  product          Product          @relation(fields: [productId], references: [id])

  @@map("inventory_lines")
}

// ─── MAINTENANCE ─────────────────────────────────────────────────────────────

model Equipment {
  id              String    @id @default(cuid())
  companyId       String
  code            String
  name            String
  type            String    @default("MACHINE")
  location        String?
  manufacturer    String?
  model           String?
  serialNumber    String?
  purchaseDate    DateTime?
  status          String    @default("ACTIVE")
  lastMaintenance DateTime?
  nextMaintenance DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  company             Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  maintenanceRequests MaintenanceRequest[]
  maintenanceOrders   MaintenanceOrder[]
  maintenanceLogs     MaintenanceLog[]
  workCenters         WorkCenter[]

  @@map("equipment")
}

model MaintenanceRequest {
  id          String    @id @default(cuid())
  companyId   String
  number      String
  equipmentId String
  title       String
  description String?
  type        String    @default("BREAKDOWN")
  priority    String    @default("MEDIUM")
  status      String    @default("OPEN")
  reportedAt  DateTime  @default(now())
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  equipment         Equipment          @relation(fields: [equipmentId], references: [id])
  maintenanceOrders MaintenanceOrder[]

  @@map("maintenance_requests")
}

model MaintenanceOrder {
  id             String    @id @default(cuid())
  companyId      String
  number         String
  equipmentId    String
  requestId      String?
  title          String
  description    String?
  type           String    @default("CORRECTIVE")
  status         String    @default("PLANNED")
  priority       String    @default("MEDIUM")
  plannedDate    DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  estimatedHours Float     @default(0)
  actualHours    Float     @default(0)
  laborCost      Float     @default(0)
  partsCost      Float     @default(0)
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  company   Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  equipment Equipment           @relation(fields: [equipmentId], references: [id])
  request   MaintenanceRequest? @relation(fields: [requestId], references: [id])
  logs      MaintenanceLog[]

  @@map("maintenance_orders")
}

model MaintenanceLog {
  id          String   @id @default(cuid())
  companyId   String
  equipmentId String
  orderId     String?
  action      String
  description String?
  createdAt   DateTime @default(now())

  company   Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  equipment Equipment         @relation(fields: [equipmentId], references: [id])
  order     MaintenanceOrder? @relation(fields: [orderId], references: [id])

  @@map("maintenance_logs")
}

// ─── PRODUCTION ───────────────────────────────────────────────────────────────

model WorkCenter {
  id          String   @id @default(cuid())
  companyId   String
  code        String
  name        String
  type        String   @default("MACHINE")
  capacity    Float    @default(8)
  status      String   @default("ACTIVE")
  equipmentId String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company    Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  equipment  Equipment?            @relation(fields: [equipmentId], references: [id])
  operations ProductionOperation[]

  @@map("work_centers")
}

model Bom {
  id          String   @id @default(cuid())
  companyId   String
  productId   String
  version     String   @default("1.0")
  isActive    Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product          Product           @relation(fields: [productId], references: [id])
  items            BomItem[]
  productionOrders ProductionOrder[]

  @@map("boms")
}

model BomItem {
  id        String @id @default(cuid())
  bomId     String
  productId String
  quantity  Float
  unit      String @default("pcs")

  bom     Bom     @relation(fields: [bomId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("bom_items")
}

model ProductionOrder {
  id           String    @id @default(cuid())
  companyId    String
  number       String
  productId    String
  bomId        String?
  quantity     Float
  unit         String    @default("pcs")
  status       String    @default("DRAFT")
  priority     String    @default("MEDIUM")
  plannedStart DateTime?
  plannedEnd   DateTime?
  actualStart  DateTime?
  actualEnd    DateTime?
  producedQty  Float     @default(0)
  materialCost Float     @default(0)
  laborCost    Float     @default(0)
  machineCost  Float     @default(0)
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  company    Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product    Product               @relation(fields: [productId], references: [id])
  bom        Bom?                  @relation(fields: [bomId], references: [id])
  operations ProductionOperation[]

  @@map("production_orders")
}

model ProductionOperation {
  id                String    @id @default(cuid())
  productionOrderId String
  workCenterId      String?
  sequence          Int
  name              String
  description       String?
  status            String    @default("PENDING")
  estimatedHours    Float     @default(0)
  actualHours       Float     @default(0)
  startedAt         DateTime?
  completedAt       DateTime?

  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  workCenter      WorkCenter?     @relation(fields: [workCenterId], references: [id])

  @@map("production_operations")
}

// ─── RECRUITMENT ──────────────────────────────────────────────────────────────

model Candidate {
  id        String         @id @default(cuid())
  companyId String
  name      String
  position  String
  email     String?
  phone     String?
  stage     CandidateStage @default(APPLIED)
  note      String?
  cvUrl     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("candidates")
}

enum CandidateStage {
  APPLIED
  INTERVIEW
  OFFER
  HIRED
  REJECTED
}
